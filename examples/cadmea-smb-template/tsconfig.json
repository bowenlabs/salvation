{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types/latest"]
  },
  "include": ["src/**/*", "cadmea.config.ts"],
  "exclude": ["node_modules", "dist"]
}
