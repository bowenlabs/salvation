{
  "name": "@thebes/cadmea",
  "version": "1.1.1",
  "description": "Generic SolidJS admin-UI components for @thebes/cadmus/cms collections",
  "author": "BowenLabs <hello@bowenlabs.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bowenlabs/project-thebes",
    "directory": "packages/cadmea"
  },
  "homepage": "https://github.com/bowenlabs/project-thebes/tree/main/packages/cadmea#readme",
  "bugs": {
    "url": "https://github.com/bowenlabs/project-thebes/issues"
  },
  "keywords": [
    "cloudflare",
    "cms",
    "solidjs",
    "tanstack-start",
    "admin-ui"
  ],
  "type": "module",
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@tanstack/solid-query": ">=5.0.0",
    "@tanstack/solid-router": ">=1.0.0",
    "@thebes/cadmus": "workspace:^",
    "solid-js": ">=1.9.0"
  },
  "dependencies": {
    "@tanstack/solid-form": "^1.33.0",
    "@tanstack/solid-table": "^8.21.3",
    "@tiptap/core": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@solidjs/testing-library": "latest",
    "@tanstack/solid-query": "^5.101.0",
    "@tanstack/solid-router": "latest",
    "@testing-library/dom": "latest",
    "@testing-library/jest-dom": "latest",
    "@thebes/cadmus": "workspace:^",
    "babel-preset-solid": "^1.9.12",
    "jsdom": "latest",
    "solid-js": "^1.9.13",
    "typescript": "latest",
    "vite-plugin-solid": "latest",
    "vite-plus": "latest",
    "vitest": "latest"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index/server.js",
  "module": "./dist/index/server.js",
  "types": "./dist/index/index.d.ts",
  "browser": {
    "./dist/index/server.js": "./dist/index/index.js",
    "./dist/tanstack-start/server.js": "./dist/tanstack-start/index.js"
  },
  "exports": {
    ".": {
      "worker": {
        "import": {
          "types": "./dist/index/index.d.ts",
          "default": "./dist/index/server.js"
        }
      },
      "browser": {
        "import": {
          "types": "./dist/index/index.d.ts",
          "default": "./dist/index/index.js"
        }
      },
      "deno": {
        "import": {
          "types": "./dist/index/index.d.ts",
          "default": "./dist/index/server.js"
        }
      },
      "node": {
        "import": {
          "types": "./dist/index/index.d.ts",
          "default": "./dist/index/server.js"
        }
      },
      "import": {
        "types": "./dist/index/index.d.ts",
        "default": "./dist/index/index.js"
      }
    },
    "./tanstack-start": {
      "worker": {
        "import": {
          "types": "./dist/tanstack-start/index.d.ts",
          "default": "./dist/tanstack-start/server.js"
        }
      },
      "browser": {
        "import": {
          "types": "./dist/tanstack-start/index.d.ts",
          "default": "./dist/tanstack-start/index.js"
        }
      },
      "deno": {
        "import": {
          "types": "./dist/tanstack-start/index.d.ts",
          "default": "./dist/tanstack-start/server.js"
        }
      },
      "node": {
        "import": {
          "types": "./dist/tanstack-start/index.d.ts",
          "default": "./dist/tanstack-start/server.js"
        }
      },
      "import": {
        "types": "./dist/tanstack-start/index.d.ts",
        "default": "./dist/tanstack-start/index.js"
      }
    }
  },
  "typesVersions": {
    "*": {
      "tanstack-start": [
        "./dist/tanstack-start/index.d.ts"
      ]
    }
  }
}
