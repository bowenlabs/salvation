---
import Layout from "../layouts/layout.astro";

// The login page lives in Worker 1 (Astro SSR) — Worker 2's `/admin/*`
// guard redirects here via an absolute cross-Worker URL rather than a
// same-app route. See CLAUDE.md "Authentication".
const redirectTarget = Astro.url.searchParams.get("redirect") ?? "/admin";
const error = Astro.url.searchParams.get("error");
---

<Layout title="Log in — Thebes" showChrome={false}>
	<main class="flex min-h-screen flex-col items-center justify-center px-[var(--spacing-container-x)]">
		<div class="card w-full max-w-sm bg-base-100 shadow-lg">
			<div class="card-body gap-4">
				<h1 class="font-display text-2xl font-semibold">Log in</h1>

				{error === "invalid" && (
					<p role="alert" class="alert alert-error text-sm">
						That link is invalid or has expired. Request a new one below.
					</p>
				)}
				{error === "unauthorized" && (
					<p role="alert" class="alert alert-error text-sm">
						No account found for that link.
					</p>
				)}

				<form id="magic-link-form" class="flex flex-col gap-3">
					<label for="email" class="label">
						<span class="label-text">Email</span>
					</label>
					<input
						id="email"
						name="email"
						type="email"
						required
						autocomplete="email"
						class="input input-bordered w-full"
					/>
					<input type="hidden" name="redirect" value={redirectTarget} />
					<button type="submit" class="btn btn-primary mt-2">Send sign-in link</button>
				</form>

				<p id="magic-link-sent" hidden class="text-sm opacity-80">
					Check your email for a sign-in link.
				</p>
				<p id="magic-link-dev-notice" hidden class="text-sm opacity-80">
					Dev mode — the link was logged to the server console instead of emailed.
				</p>
			</div>
		</div>
	</main>

	<script>
		const form = document.getElementById("magic-link-form") as HTMLFormElement;
		const sentMessage = document.getElementById("magic-link-sent")!;
		const devNotice = document.getElementById("magic-link-dev-notice")!;

		form.addEventListener("submit", async (event) => {
			event.preventDefault();
			const email = (form.elements.namedItem("email") as HTMLInputElement).value;
			const redirect = (form.elements.namedItem("redirect") as HTMLInputElement).value;

			await fetch("/api/auth/magic-link", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ email, redirect }),
			});

			form.hidden = true;
			sentMessage.hidden = false;
			// The route never reports back whether the email actually sent
			// (vs. logged to console in dev) — both look identical from the
			// client's perspective by design, so this notice is unconditional.
			devNotice.hidden = false;
		});
	</script>
</Layout>
