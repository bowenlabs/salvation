---
export const prerender = false;

import { env } from "cloudflare:workers";
import { pages } from "@core/db/schema.generated";
import { parseBlocks } from "@core/lib/blocks";
import { db } from "@thebes/cadmus/db";
import { and, eq } from "drizzle-orm";
import BlockRenderer from "../components/BlockRenderer.astro";
import Layout from "../layouts/layout.astro";

// Slugs with their own dedicated route — must be listed here or this
// catch-all would shadow them (see SECTION_1_PLAN.md Phase 5 gotchas).
const RESERVED_SLUGS = new Set(["home", "about", "contact", "coming-soon"]);

const { slug } = Astro.params;

if (!slug || RESERVED_SLUGS.has(slug)) {
  return Astro.rewrite("/404");
}

const page = await db(env.DB, { pages })
  .select()
  .from(pages)
  .where(and(eq(pages.slug, slug), eq(pages.status, "published")))
  .get();

if (!page) {
  return Astro.rewrite("/404");
}

Astro.response.headers.set("Cache-Control", "public, max-age=60");

const blocks = parseBlocks(page.blocks);
---

<Layout title={page.title} seo={page}>
	<article class="container mx-auto max-w-3xl px-[var(--spacing-container-x)] py-[var(--spacing-section-y)]">
		<h1 class="font-display text-3xl font-semibold">{page.title}</h1>
		<div class="mt-8">
			<BlockRenderer blocks={blocks} />
		</div>
	</article>
</Layout>
