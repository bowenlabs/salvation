---
import { env } from "cloudflare:workers";
import type { Block } from "@core/lib/blocks";
import { renderRichText } from "@core/lib/blocks";
import { createR2ImageService } from "@core/lib/image-service";

interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;
// Never read block.url directly — always through ImageService.render(),
// so swapping in a Cloudflare Images extension later (Section 3+) needs
// no change here. render() is a pass-through today (see image-service.ts).
const imageService = createR2ImageService(env.R2, env.MEDIA_URL);
---

{
  blocks.map((block) => {
    switch (block.type) {
      case "richText":
        return (
          <div
            class="prose max-w-none"
            set:html={renderRichText(block.content)}
          />
        );
      case "image": {
        const rendered = imageService.render({
          url: block.url,
          alt: block.alt,
        });
        return (
          <figure>
            <img
              src={rendered.src}
              srcset={rendered.srcset}
              sizes={rendered.sizes}
              alt={block.alt}
              loading="lazy"
              decoding="async"
            />
            {block.caption && <figcaption>{block.caption}</figcaption>}
          </figure>
        );
      }
      case "hero":
        return (
          <section class="hero">
            <h1>{block.heading}</h1>
            {block.subtext && <p>{block.subtext}</p>}
            {block.ctaLabel && block.ctaHref && (
              <a class="btn btn-primary" href={block.ctaHref}>
                {block.ctaLabel}
              </a>
            )}
          </section>
        );
      case "divider":
        return <hr />;
      default:
        return null;
    }
  })
}
