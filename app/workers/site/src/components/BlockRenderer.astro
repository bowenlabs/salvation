---
import type { Block } from "@core/lib/blocks";
import { renderRichText } from "@core/lib/blocks";

interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;
---

{
  blocks.map((block) => {
    switch (block.type) {
      case "richText":
        return (
          <div
            class="prose max-w-none"
            set:html={renderRichText(block.content)}
          />
        );
      case "image":
        return (
          <figure>
            <img
              src={block.url}
              alt={block.alt}
              loading="lazy"
              decoding="async"
            />
            {block.caption && <figcaption>{block.caption}</figcaption>}
          </figure>
        );
      case "hero":
        return (
          <section class="hero">
            <h1>{block.heading}</h1>
            {block.subtext && <p>{block.subtext}</p>}
            {block.ctaLabel && block.ctaHref && (
              <a class="btn btn-primary" href={block.ctaHref}>
                {block.ctaLabel}
              </a>
            )}
          </section>
        );
      case "divider":
        return <hr />;
      default:
        return null;
    }
  })
}
