---
export interface SocialLink {
  platform: string;
  url: string;
}

interface Props {
  siteName: string;
  socialLinks: SocialLink[];
  contactEmail?: string | null;
  contactPhone?: string | null;
  contactAddress?: string | null;
}

const { siteName, socialLinks, contactEmail, contactPhone, contactAddress } =
  Astro.props;

// Phosphor icon names per platform — falls back to a generic link glyph
// for anything not in this map (see CLAUDE.md "Icons" — Phosphor only).
const PLATFORM_ICONS: Record<string, string> = {
  x: "ph-x-logo",
  twitter: "ph-x-logo",
  instagram: "ph-instagram-logo",
  facebook: "ph-facebook-logo",
  linkedin: "ph-linkedin-logo",
  youtube: "ph-youtube-logo",
  tiktok: "ph-tiktok-logo",
  github: "ph-github-logo",
};

const year = new Date().getFullYear();
---

<footer class="bg-[var(--footer,_var(--color-base-200))] text-[var(--footer-foreground,_var(--color-base-content))]">
	<div class="container mx-auto flex flex-col gap-6 px-[var(--spacing-container-x)] py-[var(--spacing-section-y)] md:flex-row md:items-start md:justify-between">
		<div class="flex flex-col gap-2">
			{contactEmail && (
				<a href={`mailto:${contactEmail}`} class="focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2">
					{contactEmail}
				</a>
			)}
			{contactPhone && (
				<a href={`tel:${contactPhone}`} class="focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2">
					{contactPhone}
				</a>
			)}
			{contactAddress && <address class="not-italic">{contactAddress}</address>}
		</div>

		{socialLinks.length > 0 && (
			<ul class="flex items-center gap-4" aria-label="Social media links">
				{socialLinks.map((link) => (
					<li>
						<a
							href={link.url}
							target="_blank"
							rel="noopener noreferrer"
							aria-label={link.platform}
							class="focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
						>
							<i
								class={`ph ${PLATFORM_ICONS[link.platform.toLowerCase()] ?? "ph-link"} text-xl`}
								aria-hidden="true"
							></i>
						</a>
					</li>
				))}
			</ul>
		)}
	</div>
	<div class="container mx-auto px-[var(--spacing-container-x)] pb-[var(--spacing-section-y)] text-sm">
		&copy; {year} {siteName}. All rights reserved.
	</div>
</footer>
