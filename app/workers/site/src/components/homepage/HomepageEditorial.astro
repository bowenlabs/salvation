---
import type { SiteSettings } from "@core/lib/get-site-settings";

interface Props {
  settings: SiteSettings | null;
  heroTitle: string;
  heroBody?: string | null;
}

const { settings, heroTitle, heroBody } = Astro.props;
---

<article class="container mx-auto max-w-3xl px-[var(--container-padding-x)] py-[var(--section-padding-y)]">
	<h1 class="font-display text-4xl font-semibold">{heroTitle}</h1>
	{settings?.tagline && <p class="mt-2 text-lg opacity-80">{settings.tagline}</p>}
	{heroBody && <div class="prose mt-8 max-w-none">{heroBody}</div>}
</article>
