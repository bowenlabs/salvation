---
import type { SiteSettings } from "@core/lib/get-site-settings";

interface Props {
  settings: SiteSettings | null;
  heroTitle: string;
  heroBody?: string | null;
}

const { settings, heroTitle, heroBody } = Astro.props;
const ctaHref = settings?.contactEmail ? "/contact" : "/about";
---

<section class="flex min-h-[70vh] flex-col items-center justify-center gap-6 px-[var(--spacing-container-x)] text-center">
	<h1 class="font-display text-5xl font-semibold">{heroTitle}</h1>
	{heroBody && <p class="max-w-xl text-lg opacity-80">{heroBody}</p>}
	<a href={ctaHref} class="btn btn-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2">
		Get in touch
	</a>
</section>
