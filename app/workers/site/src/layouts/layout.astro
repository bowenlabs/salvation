---
import { ClientRouter } from "astro:transitions";
import { env } from "cloudflare:workers";
import { pages } from "@core/db/schema.generated";
import { getSiteSettings } from "@core/lib/get-site-settings";
import { createImageService } from "@core/lib/image-service";
import phosphorCss from "@phosphor-icons/web/regular?url";
import { buildTokenStyle, getFontConfig } from "@thebes/cadmea-design-system";
import { renderSeoTags, type SeoDocument } from "@thebes/cadmea-plugin-seo";
import { db } from "@thebes/cadmus/db";
import { eq } from "drizzle-orm";
import SiteFooter, { type SocialLink } from "../components/SiteFooter.astro";
import SiteNav, { type NavLink } from "../components/SiteNav.astro";
import "../assets/app.css";

interface Props {
  title: string;
  /** Set false for chrome-less pages (coming-soon). Defaults to true. */
  showChrome?: boolean;
  /** Renders <meta name="robots" content="noindex">. Defaults to false. */
  noindex?: boolean;
  /**
   * Document whose SEO fields (from @thebes/cadmea-plugin-seo) drive the
   * <title> and meta/OG tags, with site_settings as the fallback. When
   * omitted the layout renders a plain <title> from the `title` prop.
   */
  seo?: SeoDocument;
}

const { title, showChrome = true, noindex = false, seo } = Astro.props;

const settings = await getSiteSettings(env.DB);

// Render plugin-driven SEO tags from the document, falling back to
// site-wide defaults. Output is HTML-escaped by the plugin, so set:html is
// safe here. Empty string ⇒ fall back to the plain <title> below.
const seoTags = seo
  ? renderSeoTags(seo, {
      siteName: settings?.siteName,
      metaDescription: settings?.metaDescription,
      defaultOgImageUrl: settings?.defaultOgImageUrl,
    })
  : "";
const themeName = settings?.theme ?? "citadel";
const fontConfig = getFontConfig(settings?.fontPairing);
const tokenStyle = buildTokenStyle(settings ?? {});
const darkModeClass = settings?.darkMode ? "dark" : undefined;

const configuredNavLinks = Array.isArray(settings?.navLinks)
  ? (settings.navLinks as NavLink[])
  : null;

// Falls back to an auto-built nav from published pages when the operator
// hasn't configured site_settings.navLinks yet (see issue #6 5.1).
const navLinks: NavLink[] =
  configuredNavLinks ??
  (showChrome
    ? (
        await db(env.DB, { pages })
          .select({ title: pages.title, slug: pages.slug })
          .from(pages)
          .where(eq(pages.status, "published"))
          .all()
      ).map((page) => ({ label: page.title, href: `/${page.slug}` }))
    : []);

const socialLinks: SocialLink[] = Array.isArray(settings?.socialLinks)
  ? (settings.socialLinks as SocialLink[])
  : [];

// Never read settings.logoUrl directly into an <img> — always through
// ImageService.render(), same reasoning as BlockRenderer.astro's image
// block (forward-compat with a future Cloudflare Images extension).
const imageService = createImageService(env.R2, env.MEDIA_URL);
const renderedLogo = settings?.logoUrl
  ? imageService.render({ url: settings.logoUrl, alt: "" })
  : null;
---

<html lang="en" data-theme={`theme-${themeName}`} class={darkModeClass}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		{seoTags ? <Fragment set:html={seoTags} /> : <title>{title}</title>}
		{noindex && <meta name="robots" content="noindex" />}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href={`/themes/theme-${themeName}.css`} />
		<link rel="stylesheet" href={fontConfig.importUrl} />
		{/* style tag MUST come after the link tags above — source order wins, see DECISIONS.md G12 */}
		<style set:html={tokenStyle} />
		<link rel="stylesheet" href={phosphorCss} />
		{env.CF_ANALYTICS_TOKEN && (
			<script
				defer
				src="https://static.cloudflareinsights.com/beacon.min.js"
				data-cf-beacon={`{"token": "${env.CF_ANALYTICS_TOKEN}"}`}
			/>
		)}
		<ClientRouter />
	</head>
	<body>
		<script>
			import { mountPreviewTokenListener } from "../scripts/preview-token-listener";
			mountPreviewTokenListener();
		</script>
		{/* Keyboard/screen-reader users would otherwise tab through the
			entire nav (and SiteNav's own links) before reaching content on
			every single page load. sr-only until focused, per the standard
			skip-link pattern. */}
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-base-100 focus:px-4 focus:py-2 focus:shadow-lg"
		>
			Skip to main content
		</a>
		{showChrome && (
			<SiteNav
				siteName={settings?.siteName ?? "Thebes"}
				logo={renderedLogo}
				links={navLinks}
				activePath={Astro.url.pathname}
			/>
		)}
		<main id="main">
			<slot />
		</main>
		{showChrome && (
			<SiteFooter
				siteName={settings?.siteName ?? "Thebes"}
				socialLinks={socialLinks}
				contactEmail={settings?.contactEmail}
				contactPhone={settings?.contactPhone}
				contactAddress={settings?.contactAddress}
			/>
		)}
	</body>
</html>
