{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "files": {
    "include": [
      "packages/**/*.ts",
      "packages/**/*.tsx",
      "apps/**/*.ts",
      "apps/**/*.tsx",
      "apps/**/*.astro",
      "examples/**/*.ts",
      "examples/**/*.tsx"
    ],
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.wrangler/**",
      "**/.astro/**"
    ]
  }
}
