{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "files": {
    "includes": [
      "**/packages/**/*.ts",
      "**/packages/**/*.tsx",
      "**/app/**/*.ts",
      "**/app/**/*.tsx",
      "**/app/**/*.astro",
      "**/examples/**/*.ts",
      "**/examples/**/*.tsx",
      "!**/node_modules",
      "!**/dist",
      "!**/.wrangler",
      "!**/.astro",
      "!**/worker-configuration.d.ts",
      "!**/routeTree.gen.ts"
    ]
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          }
        }
      }
    },
    {
      "includes": ["**/app/core/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/custom/**", "@custom/**"]
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
