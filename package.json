{
  "name": "thebes",
  "private": true,
  "version": "0.1.0",
  "description": "Cadmus framework + Citadel reference app",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.8.0"
  },
  "scripts": {
    "dev:site": "cd apps/citadel/workers/site && wrangler dev --port 3000 --persist-to ../../../../.wrangler/state",
    "dev:cms": "cd apps/citadel/workers/cms && wrangler dev --port 3001 --persist-to ../../../../.wrangler/state",
    "dev": "concurrently \"pnpm dev:site\" \"pnpm dev:cms\"",
    "build:cadmus": "cd packages/cadmus && pnpm build",
    "build:site": "cd apps/citadel/workers/site && pnpm build",
    "build:cms": "cd apps/citadel/workers/cms && pnpm build",
    "build": "pnpm build:cadmus && pnpm build:site && pnpm build:cms",
    "deploy:site": "cd apps/citadel/workers/site && wrangler deploy",
    "deploy:cms": "cd apps/citadel/workers/cms && wrangler deploy",
    "deploy": "pnpm build && pnpm deploy:site && pnpm deploy:cms",
    "db:generate": "tsx apps/citadel/scripts/generate-schema.ts && drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply citadel-db --local --config apps/citadel/workers/site/wrangler.jsonc --persist-to ./.wrangler/state",
    "db:migrate:prod": "wrangler d1 migrations apply citadel-db --remote --config apps/citadel/workers/site/wrangler.jsonc",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx apps/citadel/seed.ts",
    "lint": "biome check . && tsx apps/citadel/scripts/check-prerender.ts",
    "format": "biome format --write .",
    "test": "pnpm test:cadmus && pnpm test:int && pnpm test:e2e",
    "test:cadmus": "pnpm --filter @bowenlabs/cadmus test",
    "test:int": "vitest run tests/int",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@playwright/test": "latest",
    "concurrently": "latest",
    "drizzle-kit": "latest",
    "tsx": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  },
  "dependencies": {
    "@bowenlabs/cadmus": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "solid-js": "^1.9.13"
  }
}
