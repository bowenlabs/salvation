{
  "name": "thebes",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cadmus framework + Cadmea CMS, demoed by the Thebes app",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.8.0"
  },
  "scripts": {
    "dev:site": "cd app/workers/site && wrangler dev --port 3000 --persist-to ../../../.wrangler/state",
    "dev:cadmea": "cd app/workers/cadmea && wrangler dev --port 3001 --persist-to ../../../.wrangler/state",
    "dev": "concurrently \"pnpm dev:site\" \"pnpm dev:cadmea\"",
    "build:cadmus": "cd packages/cadmus && pnpm build",
    "build:cadmea-pkg": "cd packages/cadmea && pnpm build",
    "build:design-system": "cd packages/cadmea-design-system && pnpm build",
    "build:plugin-seo": "cd packages/cadmea-plugin-seo && pnpm build",
    "build:cf-images": "cd packages/cadmus-cloudflare-images && pnpm build",
    "build:packages": "pnpm build:cadmus && pnpm build:cadmea-pkg && pnpm build:design-system && pnpm build:plugin-seo && pnpm build:cf-images",
    "build:site": "cd app/workers/site && pnpm build",
    "build:cadmea": "cd app/workers/cadmea && pnpm build",
    "build": "pnpm build:packages && pnpm build:site && pnpm build:cadmea",
    "deploy:site": "cd app/workers/site && wrangler deploy",
    "deploy:cadmea": "cd app/workers/cadmea && wrangler deploy",
    "deploy": "pnpm build && pnpm deploy:site && pnpm deploy:cadmea",
    "db:generate": "tsx app/scripts/generate-schema.ts && drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply thebes-db --local --config app/workers/site/wrangler.jsonc --persist-to ./.wrangler/state",
    "db:migrate:prod": "wrangler d1 migrations apply thebes-db --remote --config app/workers/site/wrangler.jsonc",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx app/seed.ts",
    "lint": "biome check . && tsx app/scripts/check-prerender.ts",
    "format": "biome format --write .",
    "test": "pnpm test:cadmus && pnpm test:cadmea-pkg && pnpm test:design-system && pnpm test:plugin-seo && pnpm test:cf-images && pnpm test:int && pnpm test:e2e",
    "test:cadmus": "pnpm --filter @thebes/cadmus test",
    "test:cadmea-pkg": "pnpm --filter @thebes/cadmea test",
    "test:design-system": "pnpm --filter @thebes/cadmea-design-system test",
    "test:plugin-seo": "pnpm --filter @thebes/cadmea-plugin-seo test",
    "test:cf-images": "pnpm --filter @thebes/cadmus-cloudflare-images test",
    "test:int": "vitest run --config tests/int/vitest.config.ts",
    "test:e2e": "playwright test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:packages && changeset publish"
  },
  "devDependencies": {
    "@axe-core/playwright": "latest",
    "@biomejs/biome": "latest",
    "@changesets/cli": "latest",
    "@cloudflare/vitest-pool-workers": "latest",
    "@cloudflare/workers-types": "latest",
    "@playwright/test": "latest",
    "concurrently": "latest",
    "drizzle-kit": "latest",
    "hono": "latest",
    "tsx": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  },
  "dependencies": {
    "@thebes/cadmea-plugin-seo": "workspace:*",
    "@thebes/cadmus": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "solid-js": "^1.9.13"
  }
}
